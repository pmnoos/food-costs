<% content_for :title, "Stores" %>

<div class="min-vh-100 bg-light">
  <div class="container-fluid py-2">
    <!-- Header -->
    <div class="text-center mb-3">
      <h1 class="display-5 fw-bold text-dark mb-2">🏪 Grocery Stores</h1>
      <p class="lead text-muted">Manage your favorite grocery stores and track your shopping</p>
    </div>

    <!-- Add Store Button -->
    <div class="mb-3 d-flex justify-content-start">
      <%= link_to new_store_path, class: "btn btn-primary btn-lg px-4 py-2 fw-medium shadow" do %>
        <i class="bi bi-plus-circle me-2"></i>
        Add New Store
    <% end %>
  </div>

    <!-- Stores Grid -->
    <div class="container-fluid">
    <div class="row g-3">
      <% @stores.each do |store| %>
            </div>
            <div class="d-flex justify-content-center mt-4">
              <%= paginate @stores %>
            </div>
        <div class="col-12 col-sm-6 col-md-4 col-lg-3 col-xl-3 mb-4 d-flex align-items-stretch">
          <div class="card h-100 shadow-sm border-0 hover-shadow" style="border-radius: 1.25rem; min-width: 240px; max-width: 100%;">
            <!-- Store Header -->
            <div class="card-img-top bg-gradient-primary d-flex align-items-center justify-content-center position-relative" style="height: 130px; background: linear-gradient(135deg, #a8d5ba 0%, #b8e6b8 100%);">
              <% if store.logo.attached? %>
                <%= image_tag store.logo, class: "img-thumbnail bg-white border-0", style: "max-height: 80px; border-radius: 12px; object-fit: contain;" %>
              <% else %>
                <span class="display-1">🏪</span>
              <% end %>
              <!-- Store Count Badge -->
              <div class="position-absolute top-0 end-0 m-3">
                <span class="store-badge-count d-inline-flex align-items-center justify-content-center fw-bold shadow" style="background: var(--pastel-primary); color: var(--text-dark); border-radius: 2rem; min-width: 2.5rem; min-height: 2.5rem; font-size: 1.2rem; border: 2px solid var(--pastel-accent); box-shadow: 0 2px 8px var(--shadow-soft);">
                  <%= store.products.count %>
                </span>
              </div>
            </div>
            
            <!-- Store Content -->
            <div class="card-body d-flex flex-column">
              <div class="mb-3">
                <h5 class="card-title fw-bold text-dark mb-2"><%= store.name %></h5>
                
                <!-- Location -->
                <% if store.location.present? %>
                  <div class="d-flex align-items-center text-muted small mb-3">
                    <i class="bi bi-geo-alt me-2"></i>
                    <%= store.location %>
                  </div>
                <% end %>

                <!-- Store Stats -->
                <div class="d-flex gap-3 text-muted small mb-3">
                  <span class="d-flex align-items-center">
                    <i class="bi bi-bag me-1"></i>
                    <%= pluralize(store.products.count, 'product') %>
                  </span>
                  <% if store.products.any? %>
                    <span class="d-flex align-items-center">
                      <i class="bi bi-currency-dollar me-1"></i>
                      $<%= number_with_precision(store.products.sum(:total_cost), precision: 2) %>
                    </span>
                  <% end %>
                </div>
              </div>

              <!-- Action Buttons -->
              <div class="mt-auto d-flex gap-2">
                <form action="<%= store_path(store) %>" method="get" class="flex-fill">
                  <button type="submit" class="btn btn-outline-primary btn-lg fw-medium px-4 py-2 w-100" style="border-radius: 15px; border: 2px solid var(--pastel-primary); color: var(--text-dark); font-size: 1.08rem; background: #fff; box-shadow: 0 4px 15px var(--shadow-soft);">
                    <i class="bi bi-eye me-1"></i>
                    View Store
                  </button>
                </form>
                <form action="<%= edit_store_path(store) %>" method="get" class="flex-fill">
                  <button type="submit" class="btn btn-outline-primary btn-lg fw-medium px-4 py-2 w-100" style="border-radius: 15px; border: 2px solid var(--pastel-primary); color: var(--text-dark); font-size: 1.08rem; background: #fff; box-shadow: 0 4px 15px var(--shadow-soft);">
                    <i class="bi bi-pencil me-1"></i>
                    Edit
                  </button>
                </form>
              </div>
            </div>
          </div>
        </div>
          <% end %>
        </div>
</div>
    <!-- Empty State -->
    <% if @stores.empty? %>
      <div class="text-center py-5">
        <div class="display-1 text-muted mb-3">🏪</div>
        <h3 class="fw-bold text-dark mb-3">No stores found</h3>
        <p class="text-muted mb-4">Get started by adding your first grocery store!</p>
        <%= link_to "Add Your First Store", new_store_path, class: "btn btn-primary btn-lg" %>
      </div>
    <% end %>
  </div>
</div>
