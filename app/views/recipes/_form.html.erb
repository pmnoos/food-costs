<%= form_with model: recipe, local: true, html: { class: "card wide-card shadow-lg border-0 bg-white", style: "border-radius: 1.5rem;" } do |form| %>
  <div class="card-body py-4 px-4">
    <% if recipe.errors.any? %>
      <div class="alert alert-danger">
        <div class="d-flex">
          <div class="flex-shrink-0">
            <svg class="fs-4 text-danger" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"></path>
            </svg>
          </div>
          <div class="ms-3">
            <h6 class="alert-heading">
              <%= pluralize(recipe.errors.count, "error") %> prohibited this recipe from being saved:
            </h6>
            <ul class="mb-0">
              <% recipe.errors.full_messages.each do |message| %>
                <li><%= message %></li>
              <% end %>
            </ul>
          </div>
        </div>
      </div>
    <% end %>

    <h3 class="mb-4 fw-bold text-center" style="background: linear-gradient(90deg, #6a82fb, #fc5c7d); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;">Recipe Details</h3>
    <div class="row g-4">
      <div class="col-md-6">
        <%= form.label :name, class: "form-label" %>
        <%= form.text_field :name, class: "form-control", placeholder: "e.g., Spaghetti Carbonara" %>
      </div>

      <div class="col-md-6">
        <%= form.label :cuisine, class: "form-label" %>
        <%= form.select :cuisine, 
            options_for_select([
              ['Italian', 'Italian'],
              ['Mexican', 'Mexican'],
              ['Asian', 'Asian'],
              ['American', 'American'],
              ['Mediterranean', 'Mediterranean'],
              ['Indian', 'Indian'],
              ['French', 'French'],
              ['Other', 'Other']
            ], recipe.cuisine), 
            { prompt: "Select cuisine" }, 
            { class: "form-select" } %>
      </div>

      <div class="col-md-6">
        <%= form.label :image, "Meal Image", class: "form-label" %>
        <%= form.file_field :image, class: "form-control", accept: "image/*" %>
        <% if recipe.image.attached? %>
          <div class="mt-2 d-flex align-items-center gap-2">
            <%= image_tag image_source(recipe.image, :card), class: "img-thumbnail", width: 160, height: 90, style: "object-fit: cover;" %>
            <div class="form-check">
              <%= form.check_box :remove_image, class: "form-check-input" %>
              <%= form.label :remove_image, "Remove meal image", class: "form-check-label" %>
            </div>
          </div>
        <% end %>
      </div>

      <div class="col-md-6">
        <%= form.label :cuisine_flag, "Cuisine Flag", class: "form-label" %>
        <%= form.file_field :cuisine_flag, class: "form-control", accept: "image/*" %>
        <% if recipe.cuisine_flag.attached? %>
          <div class="mt-2 d-flex align-items-center gap-2">
            <%= image_tag image_source(recipe.cuisine_flag, :preview), class: "img-thumbnail", width: 120, height: 75, style: "object-fit: contain;" %>
            <div class="form-check">
              <%= form.check_box :remove_cuisine_flag, class: "form-check-input" %>
              <%= form.label :remove_cuisine_flag, "Remove flag", class: "form-check-label" %>
            </div>
          </div>
        <% end %>
      </div>

      <div class="col-md-4">
        <%= form.label :difficulty, class: "form-label" %>
        <%= form.select :difficulty, 
            options_for_select([
              ['Easy', 'Easy'],
              ['Medium', 'Medium'],
              ['Hard', 'Hard']
            ], recipe.difficulty), 
            { prompt: "Select difficulty" }, 
            { class: "form-select" } %>
      </div>

      <div class="col-md-4">
        <%= form.label :prep_time, "Prep Time (minutes)", class: "form-label" %>
        <%= form.number_field :prep_time, class: "form-control", placeholder: "30" %>
      </div>

      <div class="col-md-4">
        <%= form.label :cook_time, "Cook Time (minutes)", class: "form-label" %>
        <%= form.number_field :cook_time, class: "form-control", placeholder: "45" %>
      </div>

      <div class="col-md-6">
        <%= form.label :servings, class: "form-label" %>
        <%= form.number_field :servings, class: "form-control", placeholder: "4" %>
      </div>

      <div class="col-md-6">
        <%= form.label :occasion, class: "form-label" %>
        <%= form.select :occasion, 
            options_for_select([
              ['Weeknight Dinner', 'Weeknight Dinner'],
              ['Weekend Brunch', 'Weekend Brunch'],
              ['Holiday Feast', 'Holiday Feast'],
              ['Quick Lunch', 'Quick Lunch'],
              ['Party Appetizer', 'Party Appetizer'],
              ['Dessert', 'Dessert'],
              ['Other', 'Other']
            ], recipe.occasion), 
            { prompt: "Select occasion (optional)" }, 
            { class: "form-select" } %>
      </div>

      <div class="col-12">
        <h5 class="fw-semibold mt-4 mb-2" style="color: #198754;">Nutrition (per serving)</h5>
      </div>

      <div class="col-md-3">
        <%= form.label :calories, "Calories", class: "form-label" %>
        <%= form.number_field :calories, class: "form-control", min: 0, step: 1, placeholder: "420" %>
      </div>

      <div class="col-md-3">
        <%= form.label :carbohydrates_g, "Carbs (g)", class: "form-label" %>
        <%= form.number_field :carbohydrates_g, class: "form-control", min: 0, step: 0.1, placeholder: "35.0" %>
      </div>

      <div class="col-md-3">
        <%= form.label :protein_g, "Protein (g)", class: "form-label" %>
        <%= form.number_field :protein_g, class: "form-control", min: 0, step: 0.1, placeholder: "22.0" %>
      </div>

      <div class="col-md-3">
        <%= form.label :fat_g, "Fat (g)", class: "form-label" %>
        <%= form.number_field :fat_g, class: "form-control", min: 0, step: 0.1, placeholder: "18.0" %>
      </div>

      <div class="col-md-3">
        <%= form.label :fiber_g, "Fiber (g)", class: "form-label" %>
        <%= form.number_field :fiber_g, class: "form-control", min: 0, step: 0.1, placeholder: "6.0" %>
      </div>

      <div class="col-md-3">
        <%= form.label :sugar_g, "Sugar (g)", class: "form-label" %>
        <%= form.number_field :sugar_g, class: "form-control", min: 0, step: 0.1, placeholder: "8.0" %>
      </div>

      <div class="col-md-3">
        <%= form.label :sodium_mg, "Sodium (mg)", class: "form-label" %>
        <%= form.number_field :sodium_mg, class: "form-control", min: 0, step: 1, placeholder: "560" %>
      </div>

      <div class="col-md-3">
        <%= form.label :cholesterol_mg, "Cholesterol (mg)", class: "form-label" %>
        <%= form.number_field :cholesterol_mg, class: "form-control", min: 0, step: 1, placeholder: "75" %>
      </div>


      <div class="col-12">
        <h5 class="fw-semibold mt-4 mb-2" style="color: #6a82fb;">Ingredients</h5>
        <%= form.label :ingredients, class: "form-label visually-hidden" %>
        <%= form.text_area :ingredients, class: "form-control tinymce border border-primary-subtle shadow-sm", placeholder: "List all ingredients with quantities...", rows: 6, style: "background: #f8fafc; border-radius: 0.5rem; min-height: 120px;" %>
      </div>

      <div class="col-12">
        <h5 class="fw-semibold mt-4 mb-2" style="color: #fc5c7d;">Instructions</h5>
        <%= form.label :instructions, class: "form-label visually-hidden" %>
        <%= form.text_area :instructions, class: "form-control tinymce border border-danger-subtle shadow-sm", placeholder: "Step-by-step cooking instructions...", rows: 8, style: "background: #f8fafc; border-radius: 0.5rem; min-height: 160px;" %>
      </div>

      <div class="col-12">
        <h5 class="fw-semibold mt-4 mb-2" style="color: #7b8c99;">Notes</h5>
        <%= form.label :notes, class: "form-label visually-hidden" %>
        <%= form.text_area :notes, class: "form-control border border-info-subtle shadow-sm", rows: 3, placeholder: "Any additional notes, tips, or variations...", style: "background: #f8fafc; border-radius: 0.5rem;" %>
      </div>
    </div>

    <div class="d-flex gap-2 mt-4 justify-content-center">
      <%= form.submit "Save Changes", class: "btn btn-primary px-4 py-2 fw-semibold shadow-sm" %>
      <%= link_to "Cancel", recipes_path, class: "btn btn-outline-secondary px-4 py-2 fw-semibold" %>
    </div>
  </div>
<% end %> 