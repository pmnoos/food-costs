<% content_for :title, "Product Details" %>

<div class="row justify-content-center">
  <div class="col-lg-10">
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-start align-items-md-center mb-4">
    <div>
        <h1 class="h2">Product Details</h1>
    </div>
      <div class="d-flex flex-column flex-md-row gap-2 mt-3 mt-md-0">
        <%= link_to edit_product_path(@product), class: "btn btn-primary d-inline-flex align-items-center" do %>
          <svg class="me-2" width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path>
        </svg>
        Edit
      <% end %>
        <%= link_to products_path, class: "btn btn-outline-secondary d-inline-flex align-items-center" do %>
          <svg class="me-2" width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
        </svg>
        Back
      <% end %>
    </div>
  </div>

    <div class="row">
      <div class="min-vh-100" style="background: linear-gradient(135deg, #f8fafc 0%, #e6e6fa 100%);">
        <div class="container py-5">
          <div class="row justify-content-center mb-4">
            <div class="col-lg-10">
              <div class="d-flex flex-column flex-md-row justify-content-between align-items-start align-items-md-center mb-4">
                <div>
                  <h1 class="display-5 fw-bold mb-2" style="color: #6a82fb; letter-spacing: 1px;">Product Details</h1>
                </div>
                <div class="d-flex flex-column flex-md-row gap-2 mt-3 mt-md-0">
                  <%= link_to edit_product_path(@product), class: "btn btn-primary d-inline-flex align-items-center px-4 py-2 fw-semibold shadow-sm" do %>
                    <i class="bi bi-pencil-square me-2"></i>
                    Edit
                  <% end %>
                  <%= link_to products_path, class: "btn btn-outline-secondary d-inline-flex align-items-center px-4 py-2 fw-semibold" do %>
                    <i class="bi bi-arrow-left me-2"></i>
                    Back
                  <% end %>
                </div>
              </div>
              <div class="row g-4">
                <div class="col-lg-8">
                  <div class="card shadow-lg border-0 mb-4" style="border-radius: 1.5rem;">
                    <div class="card-header bg-white border-0" style="border-radius: 1.5rem 1.5rem 0 0;">
                      <h5 class="mb-0 fw-bold" style="color: #6a82fb;">Product Information</h5>
                    </div>
                    <div class="card-body">
                      <div class="table-responsive">
                        <table class="table table-borderless align-middle mb-0">
                          <tbody>
                            <tr>
                              <th class="product-label-bg text-dark">Product Name</th>
                              <td class="fw-semibold"><%= @product.name %></td>
                            </tr>
                            <tr>
                              <th class="product-label-bg text-dark">Purchase Date</th>
                              <td><%= @product.purchase_date&.strftime("%B %d, %Y") || "Not specified" %></td>
                            </tr>
                            <tr>
                              <th class="product-label-bg text-dark">Store</th>
                              <td><%= @product.store&.name.presence || "Not specified" %></td>
                            </tr>
                            <tr>
                              <th class="product-label-bg text-dark">Unit</th>
                              <td>
                                <% unit_labels = {
                                  'lb' => 'Pound (lb)',
                                  'kg' => 'Kilogram (kg)',
                                  'oz' => 'Ounce (oz)',
                                  'g'  => 'Gram (g)',
                                  'pc' => 'Piece (pc)',
                                  'pk' => 'Pack (pk)',
                                  'btl'=> 'Bottle (btl)',
                                  'can'=> 'Can (can)',
                                  'box'=> 'Box (box)',
                                  'bag'=> 'Bag (bag)',
                                  'other' => 'Other'
                                } %>
                                <%= @product.unit.present? ? (unit_labels[@product.unit] || @product.unit) : "Not specified" %>
                              </td>
                            </tr>
                            <tr>
                              <th class="product-label-bg text-dark">Unit Price</th>
                              <td class="fw-bold"><%= number_to_currency(@product.unit_price) %></td>
                            </tr>
                            <tr>
                              <th class="product-label-bg text-dark">Quantity</th>
                              <td><%= @product.quantity %></td>
                            </tr>
                            <tr>
                              <th class="product-label-bg text-dark">Total Cost</th>
                              <td>
                                <span class="fw-bold <%= @product.total_cost < 0 ? 'text-danger' : 'text-success' %>">
                                  <%= number_to_currency(@product.total_cost) %>
                                </span>
                              </td>
                            </tr>
                          </tbody>
                        </table>
                      </div>
                    </div>
                  </div>
                </div>
                <div class="col-lg-5 col-xl-5">
                  <div class="card shadow-lg border-0" style="border-radius: 1.5rem; min-width: 320px;">
                    <div class="card-header bg-white border-0" style="border-radius: 1.5rem 1.5rem 0 0;">
                      <h6 class="mb-0 fw-bold" style="color: #7b8c99;">Quick Actions</h6>
                    </div>
                    <div class="card-body">
                      <div class="d-grid gap-3">
                        <%= link_to new_product_path(store_id: @product.store_id), class: "btn btn-outline-primary px-4 py-2 fw-semibold" do %>
                          <i class="bi bi-plus-circle me-2"></i>
                          Add Another Product
                        <% end %>
                        <%= link_to products_path(store_id: @product.store_id), class: "btn btn-outline-info px-4 py-2 fw-semibold" do %>
                          <i class="bi bi-shop me-2"></i>
                          View Store Products
                        <% end %>
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
