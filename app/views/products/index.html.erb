<% content_for :title, "Products" %>

<div class="container-fluid py-2">

  <%# ── Page heading ───────────────────────────────────────── %>
  <div class="d-flex flex-wrap align-items-center justify-content-between mb-4 gap-3">
    <div>
      <h1 class="display-5 fw-bold mb-1">🛒 Grocery Products</h1>
      <p class="lead text-muted mb-0">Track your grocery purchases and manage costs</p>
    </div>
    <%= link_to new_product_path, class: "btn btn-primary btn-lg px-4" do %>
      <i class="bi bi-plus-circle me-2"></i>Add New Product
    <% end %>
  </div>

  <%# ── Search & filters ──────────────────────────────────── %>
  <div class="card shadow-lg mb-4">
    <div class="card-body p-4">
      <%= form_with url: products_path, method: :get, local: true do |form| %>
        <div class="row g-3">
          <div class="col-md-6 col-lg-3">
            <%= form.label :name, "Product Name", class: "form-label" %>
            <%= form.select :name,
              options_for_select(@product_names, params[:name]),
              { prompt: "All products" },
              { class: "form-select" } %>
          </div>

          <div class="col-md-6 col-lg-3">
            <%= form.label :store_id, "Store", class: "form-label" %>
            <%= form.select :store_id,
              options_from_collection_for_select(@stores, :id, :name, params[:store_id]),
                  { prompt: "All stores" },
                  { class: "form-select" } %>
          </div>


          <div class="col-md-6 col-lg-3">
            <%= form.label :purchase_date, "Purchase Date", class: "form-label" %>
            <%= form.date_field :purchase_date, value: params[:purchase_date], class: "form-control" %>
          </div>

          <div class="col-md-6 col-lg-2 d-flex align-items-end">
            <div class="d-grid gap-2 w-100">
              <%= form.submit "Search", class: "btn btn-primary" %>
              <%= link_to "Clear", products_path, class: "btn btn-outline-secondary" %>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  </div>


  <%# ── Products table ─────────────────────────────────────── %>
  <% if @products.any? %>
    <div class="table-responsive">
      <table class="table table-bordered table-striped align-middle">
        <thead class="table-light">
          <tr>
            <th>Name</th>
            <th>Store</th>
            <th>Quantity</th>
            <th>Unit</th>
            <th>Purchase Date</th>
            <th>Unit Price</th>
            <th>Total Cost</th>
            <th class="text-center">Actions</th>
          </tr>
        </thead>
        <tbody>
          <% @products.each do |product| %>
            <tr>
              <td><%= product.name %></td>
              <td><%= product.store&.name %></td>
              <td><%= product.quantity %></td>
              <td><%= product.unit %></td>
              <td><%= product.purchase_date&.strftime("%b %d, %Y") || product.created_at.strftime("%b %d, %Y") %></td>
              <td><%= number_to_currency(product.unit_price) %></td>
              <td class="fw-bold <%= product.total_cost && product.total_cost < 0 ? 'text-danger' : 'text-success' %>"><%= number_to_currency(product.total_cost) %></td>
              <td class="text-center">
                <%= link_to raw('<i class="bi bi-eye me-1"></i>View'), product_path(product), class: "btn btn-outline-primary btn-sm me-1" %>
                <%= link_to raw('<i class="bi bi-pencil me-1"></i>Edit'), edit_product_path(product), class: "btn btn-outline-secondary btn-sm" %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>

    <%# ── Pagination ─────────────────────────────────────────── %>
    <div class="d-flex justify-content-center mt-4">
      <%= paginate @products %>
    </div>

    <%# ── Export / print ─────────────────────────────────────── %>
    <div class="d-flex justify-content-center gap-3 mt-4">
      <button type="button" class="btn btn-outline-secondary" onclick="exportToCSV()">
        <i class="bi bi-download me-2"></i>Export CSV
      </button>
      <button type="button" class="btn btn-outline-secondary" onclick="window.print()">
        <i class="bi bi-printer me-2"></i>Print
      </button>
    </div>

  <% else %>
    <%# ── Empty state ─────────────────────────────────────────── %>
    <div class="text-center py-5">
      <div class="display-1 mb-3">🛒</div>
      <h3 class="fw-bold mb-3">No products found</h3>
      <p class="text-muted mb-4">Try adjusting your filters or add your first product!</p>
      <%= link_to "Add Your First Product", new_product_path, class: "btn btn-primary btn-lg" %>
    </div>
  <% end %>



</div>

<script>
  function exportToCSV() {
    // TODO: implement CSV export
    console.log('Export CSV clicked');
  }
</script>
