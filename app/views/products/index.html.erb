<% content_for :title, "Products" %>

<div class="container-fluid py-2">

  <%# ── Page heading ───────────────────────────────────────── %>
  <div class="d-flex flex-wrap align-items-center justify-content-between mb-4 gap-3">
    <div>
      <h1 class="display-5 fw-bold mb-1">🛒 Grocery Products</h1>
      <p class="lead text-muted mb-0">Track your grocery purchases and manage costs</p>
    </div>
    <%= link_to new_product_path, class: "btn btn-primary btn-lg px-4" do %>
      <i class="bi bi-plus-circle me-2"></i>Add New Product
    <% end %>
  </div>

  <%# ── Search & filters ──────────────────────────────────── %>
  <div class="card shadow-lg mb-4">
    <div class="card-body p-4">
      <%= form_with url: products_path, method: :get, local: true do |form| %>
        <div class="row g-3">
          <div class="col-md-6 col-lg-3">
            <%= form.label :name, "Product Name", class: "form-label" %>
            <%= form.text_field :name, value: params[:name], class: "form-control", placeholder: "Search by name…" %>
          </div>

          <div class="col-md-6 col-lg-3">
            <%= form.label :store_id, "Store", class: "form-label" %>
            <%= form.select :store_id,
                  options_from_collection_for_select(Store.all, :id, :name, params[:store_id]),
                  { prompt: "All stores" },
                  { class: "form-select" } %>
          </div>

          <div class="col-md-6 col-lg-2">
            <%= form.label :min_price, "Min Price", class: "form-label" %>
            <%= form.number_field :min_price, value: params[:min_price], class: "form-control", step: "0.01", placeholder: "0.00" %>
          </div>

          <div class="col-md-6 col-lg-2">
            <%= form.label :max_price, "Max Price", class: "form-label" %>
            <%= form.number_field :max_price, value: params[:max_price], class: "form-control", step: "0.01", placeholder: "0.00" %>
          </div>

          <div class="col-md-6 col-lg-2 d-flex align-items-end">
            <div class="d-grid gap-2 w-100">
              <%= form.submit "Search", class: "btn btn-primary" %>
              <%= link_to "Clear", products_path, class: "btn btn-outline-secondary" %>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  </div>

  <%# ── Products grid ──────────────────────────────────────── %>
  <% if @products.any? %>
    <div class="row g-3">
      <% @products.each do |product| %>
        <div class="col-12 col-sm-6 col-md-4 col-lg-3 d-flex align-items-stretch">
          <div class="card h-100 w-100">
            <%# Product colour header %>
            <div class="card-img-top d-flex align-items-center justify-content-center position-relative"
                 style="height: 150px; background: linear-gradient(135deg, var(--pastel-cool) 0%, var(--pastel-lavender) 100%);">
              <span style="font-size: 3rem;">🛒</span>
              <div class="position-absolute top-0 end-0 m-3 bg-white bg-opacity-90 px-3 py-1 rounded-pill small fw-medium">
                <%= number_to_currency(product.total_cost) %>
              </div>
            </div>

            <div class="card-body d-flex flex-column">
              <h5 class="card-title mb-2"><%= product.name %></h5>

              <div class="d-flex flex-wrap gap-2 mb-3">
                <span class="badge"><%= product.quantity %> <%= product.unit %></span>
                <span class="badge badge-store"><%= product.store.name %></span>
                <% if product.purchase_date.present? %>
                  <span class="badge badge-date"><%= product.purchase_date.strftime("%b %d, %Y") %></span>
                <% end %>
              </div>

              <div class="d-flex justify-content-between align-items-center mb-3">
                <span class="text-muted small">Unit Price: <%= number_to_currency(product.unit_price) %></span>
                <span class="fw-bold fs-5 <%= product.total_cost < 0 ? 'text-danger' : 'text-success' %>">
                  <%= number_to_currency(product.total_cost) %>
                </span>
              </div>

              <div class="mt-auto d-flex gap-2">
                <%= link_to raw('<i class="bi bi-eye me-1"></i>View'), product_path(product), class: "btn btn-outline-primary btn-sm flex-fill" %>
                <%= link_to raw('<i class="bi bi-pencil me-1"></i>Edit'), edit_product_path(product), class: "btn btn-outline-secondary btn-sm" %>
              </div>
            </div>
          </div>
        </div>
      <% end %>
    </div>

    <%# ── Pagination ─────────────────────────────────────────── %>
    <div class="d-flex justify-content-center mt-4">
      <%= paginate @products %>
    </div>

    <%# ── Export / print ─────────────────────────────────────── %>
    <div class="d-flex justify-content-center gap-3 mt-4">
      <button type="button" class="btn btn-outline-secondary" onclick="exportToCSV()">
        <i class="bi bi-download me-2"></i>Export CSV
      </button>
      <button type="button" class="btn btn-outline-secondary" onclick="window.print()">
        <i class="bi bi-printer me-2"></i>Print
      </button>
    </div>

  <% else %>
    <%# ── Empty state ─────────────────────────────────────────── %>
    <div class="text-center py-5">
      <div class="display-1 mb-3">🛒</div>
      <h3 class="fw-bold mb-3">No products found</h3>
      <p class="text-muted mb-4">Try adjusting your filters or add your first product!</p>
      <%= link_to "Add Your First Product", new_product_path, class: "btn btn-primary btn-lg" %>
    </div>
  <% end %>



</div>

<script>
  function exportToCSV() {
    // TODO: implement CSV export
    console.log('Export CSV clicked');
  }
</script>
